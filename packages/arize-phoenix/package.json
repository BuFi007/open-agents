{
  "name": "@open-agents/arize-phoenix",
  "version": "0.0.0",
  "private": true,
  "description": "Arize Phoenix observability for Open Agents — OpenInference tracing (write side) + trace/dataset introspection (read side: recall, resolved-gap lookup, dataset promotion). The only package importing @arizeai/* and OTel exporters; all surfaces import from here.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./client": "./client.ts",
    "./otel": "./otel.ts",
    "./recall": "./recall.ts",
    "./experiments": "./experiments.ts",
    "./promote": "./promote.ts",
    "./types": "./types.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arizeai/openinference-semantic-conventions": "^2.3.0",
    "@arizeai/openinference-vercel": "^2.7.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.205.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/sdk-trace-node": "^2.0.0"
  },
  "devDependencies": {
    "@open-agents/tsconfig": "workspace:*",
    "@types/bun": "1.3.12",
    "@types/node": "^22"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
