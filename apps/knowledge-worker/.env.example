KNOWLEDGE_WORKER_MODE=relay
KNOWLEDGE_WORKER_ID=knowledge-relay-1
KNOWLEDGE_WORKSPACE_IDS=workspace-id-1,workspace-id-2
WORKER_REPLICA_COUNT=1
BULLMQ_NAMESPACE=bufi-knowledge
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=100
# Knowledge workers with an explicit workspace allowlist periodically scan for
# stale Typesense projections and enqueue lineage-only repair jobs.
KNOWLEDGE_REPAIR_INTERVAL_MS=60000
KNOWLEDGE_REPAIR_MAX_AGE_MS=86400000
KNOWLEDGE_REPAIR_BATCH_SIZE=500
PORT=3001

DATABASE_URL=postgresql://user:password@host/database
REDIS_URL=rediss://user:password@host:6379

OPEN_AGENTS_QUEUE_TELEMETRY_URL=https://open-agents.example/api/internal/queue-telemetry
OPEN_AGENTS_QUEUE_TELEMETRY_SECRET=replace-with-at-least-32-characters
# Optional for protected Vercel preview telemetry endpoints. Keep server-side.
VERCEL_AUTOMATION_BYPASS_SECRET=replace-with-project-automation-bypass-secret
QUEUE_TELEMETRY_INTERVAL_MS=15000

# Required for KNOWLEDGE_WORKER_MODE=knowledge or all.
TYPESENSE_URL=https://typesense.example
TYPESENSE_API_KEY=replace-with-a-scoped-key
TYPESENSE_COLLECTION=workspace_knowledge

# Optional payload-free external SLO alert webhook.
QUEUE_ALERT_WEBHOOK_URL=https://alerts.example/queue-slos
QUEUE_ALERT_WEBHOOK_SECRET=replace-with-at-least-32-characters
