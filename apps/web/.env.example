# Minimum runtime
POSTGRES_URL=
BETTER_AUTH_SECRET=

# Vercel OAuth (required for sign-in)
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github (better-auth)
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback (installation sync)
# In the GitHub App settings:
#   1. Use the GitHub App Client ID and Client Secret below
#   2. Make the app public if you want org installs to work cleanly
#   3. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# BUFI server-to-server ingress. Desk/Motora uses this shared secret to start
# durable runs; it is not a user session or a Tax Engine approval credential.
OPEN_AGENTS_BUFI_INGRESS_SECRET=
OPEN_AGENTS_QUEUE_TELEMETRY_SECRET=
# Preview/local-only end-to-end certification. Production rejects this route
# even if the enable flag is misconfigured.
OPEN_AGENTS_TAX_DOMAIN_EVENT_CERTIFICATION_ENABLED=false
OPEN_AGENTS_TAX_DOMAIN_EVENT_CERTIFICATION_SECRET=
# HMAC shared only with the Tax Engine domain-event outbox publisher.
OPEN_AGENTS_TAX_DOMAIN_EVENT_HMAC_SECRET=
BUFI_AGENT_TOOL_BROKER_SECRET=
# Human Tax approval grants must carry the exact authenticated OA session user
# ID as their subject and only the tax.invoice.authority.approve scope.
# Encrypts short-lived Desk workspace grants at rest. Falls back to the legacy
# ENCRYPTION_KEY only during migration; use a dedicated 32+ character value.
OPERATING_PACK_CREDENTIAL_KEY=

# External Tax Automation Engine agent boundary. These credentials can append
# normalized evidence and orchestrate cases, but cannot approve an invoice,
# submit authority payloads, verify FX ingress, or mark tax declared.
TAX_AUTOMATION_ENGINE_URL=
TAX_AUTOMATION_ENGINE_API_KEY=
# Dedicated server-only HMAC shared only with Tax's Open Agents agent principal.
TAX_AUTOMATION_ENGINE_AGENT_PRINCIPAL_HMAC_SECRET=
# Dedicated one-capability HMAC shared with Tax only for
# factura-e:approval:register. Never expose it to Desk or browser code.
TAX_ENGINE_OPEN_AGENTS_APPROVAL_PRINCIPAL_HMAC_SECRET=
# OA-only derivation key for stable one-use approval references. It must be
# distinct from every API, workspace-grant, agent-principal and ingress secret.
OPEN_AGENTS_TAX_APPROVAL_REF_HMAC_SECRET=
# Explicit OA owner gate in addition to Tax/Motora/ARCA production gates.
OPEN_AGENTS_TAX_AUTHORITY_PRODUCTION_APPROVED=false
TAX_AUTOMATION_EVIDENCE_INGEST_TOKEN=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
# Set to "hobby" to use lower resource defaults for constrained deployments.
# Leave unset for standard behavior.
OPEN_AGENTS_RESOURCE_PROFILE=
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
# Optional explicit base snapshot override. Vercel deployments normally resolve
# their automatically prewarmed named template without this value.
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
